{
  "mcpServers": {
    "context7": {
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "$env:CONTEXT7_API_KEY"
      },
      "lifecycle": "keep-alive",
      "directTools": true
    },
    "codegraph": {
      "command": "codegraph",
      "args": ["serve", "--mcp"],
      "lifecycle": "keep-alive",
      "directTools": [
        "codegraph_search",
        "codegraph_context",
        "codegraph_trace",
        "codegraph_explore",
        "codegraph_node",
        "codegraph_status",
        "codegraph_files"
      ]
    }
  }
}
